@model PurchaseBillViewModel
@{
    ViewData["Title"] = "CreateBill";
}

<!DOCTYPE html>
<html lang="ar">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>شركه سمارت مون</title>
    <!-- رابط الأنماط -->
    <link rel="stylesheet" href="~/css/style.css">
    <link rel="stylesheet" href="~/css/عمليه بيع جديده.css">
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>
    <div id="loading-screen">
        <div class="spinner"></div>
        <p>جاري التحميل...</p>
    </div>

    <section class="invoice-section">
        <div class="separator">
            <h2>فاتوره شراء جديده</h2>
        </div>

        <!-- Form starts here -->
        <form method="post" asp-action="CreatePurchaseBill" asp-controller="Admin">
            @* Anti-forgery token for security *@
            @Html.AntiForgeryToken()

            <!-- الصف الأول: اختيار المورد -->
            <div class="row">
                <div class="column">
                    <label for="SupplierId">اختيار المورد</label>
                    <div class="custom-select">
                        <select asp-for="SupplierId" class="form-control">
                            <option value="">اختر المورد</option>
                            @foreach (var supplier in Model.Suppliers)
                            {
                                <option value="@supplier.Id">@supplier.Name</option>
                            }
                        </select>
                        <button asp-action="AddSupplier" asp-controller="Admin" type="button" class="add-btn" id="add-custom">إضافة مورد</button>
                    </div>
                    @Html.ValidationMessageFor(m => m.SupplierId, "", new { @class = "text-danger" })
                </div>
            </div>

            <!-- الصف الثاني: اختيار الصنف والكمية والمخزن -->
            <div class="row">
                <div class="column">
                    <label for="ProductSelection">اختيار الصنف</label>
                    <div class="custom-select">
                        <select  id="ProductSelection" class="form-control">
                            <option value="">اختر الصنف</option>
                            @foreach (var product in Model.Products)
                            {
                                <option value="@product.Id">@product.Name</option>
                            }
                        </select>
                        <button asp-action="ViewProducts" asp-controller="Admin" type="button" class="add-btn" id="add-item">إضافة صنف</button>
                    </div>
                </div>

                <div class="column">
                    <label for="Quantity">الكمية</label>
                    <input type="number" id="Quantity" placeholder="ادخل الكمية" class="form-control" min="1" />
                </div>

                <div class="column">
                    <label for="InventorySelection">المخزن</label>
                    <div class="custom-select">
                        <select id="InventorySelection" class="form-control">
                            <option value="">اختر المخزن</option>
                            @foreach (var inv in Model.Inventories)
                            {
                                
                                <option value="@inv.Id">@inv.Name</option>
                            }
                        </select>
                        @* <p id="available-quantity">الكمية المتوفرة: <span id="available-quantity-text">0</span></p> *@
                    </div>
                </div>
            </div>

            <!-- الصف الثالث: سعر الشراء -->
            <div class="row">
                <div class="column">
                    <label for="SalePrice">سعر البيع</label>
                    <div class="input-group">
                        <input  type="number" id="SalePrice" placeholder="ادخل سعر البيع" min="0" step="0.01" class="form-control" />
                    </div>
                </div>
                <div class="column">
                    <label for="PurchasePrice">سعر الشراء</label>
                    <div class="input-group">
                        <input  type="number" id="PurchasePrice" placeholder="ادخل سعر الشراء" min="0" step="0.01" class="form-control" />
                        <button class="add-price-btn" type="button"><i class="bx bx-plus"></i></button>
                    </div>
                </div>
            </div>

            <!-- Hidden template for BillItemViewModel to be cloned by JavaScript -->
            <div id="bill-item-template" style="display:none;">
                <div class="bill-item" data-index="__index__">
                    <input type="hidden" name="Items[__index__].ProductId" value="__ProductId__" />
                    <input type="hidden" name="Items[__index__].ProductName" value="__ProductName__" />
                    <input type="hidden" name="Items[__index__].InventoryId" value="__InventoryId__" />
                    <input type="hidden" name="Items[__index__].InventoryName" value="__InventoryName__" />
                    <input type="hidden" name="Items[__index__].SalePrice" value="__SalePrice__" />
                    <input type="hidden" name="Items[__index__].PurchasePrice" value="__PurchasePrice__" />

                    <table class="invoice-table">
                        <thead>
                            <tr>
                                <th>الصنف</th>
                                <th>الكمية</th>
                                <th>سعر الشراء</th>
                                <th>سعر البيع</th>
                                <th>الإجمالي</th>
                                <th>المخزن</th>
                                <th>تعديل</th>
                                <th>حذف</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>__ProductName__</td>
                                <td>__Quantity__</td>
                                <td>__PurchasePrice__</td>
                                <td>__SalePrice__</td>
                                <td>__TotalPrice__</td>
                                <td>__InventoryName__</td>
                                <td><button type="button" class="edit-btn">تعديل</button></td>
                                <td><button type="button" class="delete-btn">حذف</button></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- جدول الفاتورة -->
            <table class="invoice-table">
                <thead>
                    <tr>
                        <th>الصنف</th>
                        <th>الكمية</th>
                        <th>السعر</th>
                        <th>الإجمالي</th>
                        <th>المخزن</th>
                        <th>تعديل</th>
                        <th>حذف</th>
                    </tr>
                </thead>
                <tbody id="invoice-body">
                    @for (int i = 0; i < Model.Items.Count; i++)
                    {
                        <tr>
                            <td>
                                @Html.HiddenFor(m => m.Items[i].ProductId)
                                @Html.HiddenFor(m => m.Items[i].ProductName)
                                @Html.DisplayFor(m => m.Items[i].ProductName)
                            </td>
                            <td>
                                @Html.HiddenFor(m => m.Items[i].Quantity)
                                @Html.DisplayFor(m => m.Items[i].Quantity)
                            </td>
                            <td>
                                @Html.HiddenFor(m => m.Items[i].PurchasePrice)
                                @Html.DisplayFor(m => m.Items[i].PurchasePrice)
                            </td>
                            <td>
                                @Html.HiddenFor(m => m.Items[i].Total)
                                @Html.DisplayFor(m => m.Items[i].Total)
                            </td>
                            <td>
                                @Html.HiddenFor(m => m.Items[i].InventoryId)
                                @Html.HiddenFor(m => m.Items[i].InventoryName)
                                @Html.DisplayFor(m => m.Items[i].InventoryName)
                            </td>
                            <td><button type="button" class="edit-btn">تعديل</button></td>
                            <td><button type="button" class="delete-btn">حذف</button></td>
                        </tr>
                    }
                </tbody>
            </table>

            <!-- إجمالي الفاتورة -->
            <div class="total">
                <p>الإجمالي: <span id="total-amount-text">@Model.TotalAmount</span> جنيه</p>
                @Html.HiddenFor(m => m.TotalAmount)
            </div>

            <!-- طرق الدفع والخصم -->
            <div class="row">
                <div class="column">
                    <label for="PaymentMethod">طريقة الدفع</label>
                    <select asp-for="PaymentMethod" class="form-control">
                        <option value="كاش">كاش</option>
                        <option value="آجل">آجل</option>
                    </select>
                    @Html.ValidationMessageFor(m => m.PaymentMethod, "", new { @class = "text-danger" })
                </div>

                <div class="column">
                    <label for="DiscountAmount">الخصم</label>
                    <div class="input-group">
                        <input type="number" asp-for="DiscountAmount" class="form-control" placeholder="ادخل الخصم" min="0" step="0.01" />
                        <select id="discount-type" name="DiscountType" class="form-control">
                            <option value="مبلغ">مبلغ</option>
                            <option value="نسبة">نسبة</option>
                        </select>
                        @Html.ValidationMessageFor(m => m.DiscountAmount, "", new { @class = "text-danger" })
                    </div>
                </div>
            </div>

            <!-- الدفع النقدي والخزنة -->
            <div class="row">
                <div class="column">
                    <label for="CashPaid">المبلغ نقداً</label>
                    <input type="number" asp-for="CashPaid" class="form-control" placeholder="ادخل المبلغ" min="0" step="0.01" />
                    
                </div>

                <div class="column">
                    <label for="cash-register">الخزنة</label>
                    <div class="custom-select">
                        <select asp-for="MoneyDrawer" id="CashRegister"  class="form-control">
                            <option value="">اختر الخزنة</option>
                            @foreach(var monerdrawer in Model.MoneyDrawers)
                            {
                                <option value="@monerdrawer.Name">@monerdrawer.Name</option>
                            }

                        </select>
                       
                    </div>
                </div>
            </div>

            <!-- الباقي -->
            <div class="row">
                <div class="column">
                    <div class="remaining">
                        <p>المتبقي: <span id="remaining-amount-text">@Model.RemainingBalance</span> جنيه</p>
                        @Html.HiddenFor(m => m.RemainingBalance)
                    </div>
                </div>
            </div>

            <button type="submit" class="save-btn">حفظ الفاتورة</button>
            <!-- الأزرار -->
            @* <div class="buttons">
                <button type="submit" class="save-btn">حفظ الفاتورة</button>
                <button type="button" class="print-btn">طباعة الفاتورة</button>
            </div> *@
        </form>
    </section>

    <!-- The Invoice Display Section (after saving) -->
    <div class="invoice-container">
        <div class="header">
            <div class="details">
                <p>رقم الفاتوره : <span></span></p>
                <p>التاريخ : <span></span></p>
                <p>العميل : <span></span></p>
            </div>
            <div class="logo">
                <img src="https://scontent.fcai20-4.fna.fbcdn.net/v/t39.30808-6/312805914_442776691332738_4492587391713879260_n.jpg" alt="Logo">
            </div>
        </div>

        <table class="invoice-table">
            <thead>
                <tr>
                    <th>الصنف</th>
                    <th>الكمية</th>
                    <th>السعر</th>
                    <th>الإجمالي</th>
                    <th>المخزن</th>
                </tr>
            </thead>
            <tbody>
                <!-- Populated dynamically -->
            </tbody>
        </table>

        <table class="totals">
            <tr>
                <th>الإجمالي</th>
                <td></td>
            </tr>
            <tr>
                <th>المدفوع</th>
                <td></td>
            </tr>
            <tr>
                <th>الباقي</th>
                <td></td>
            </tr>
        </table>

        <div class="footer">
            <p>الارجاع و الاستبدال خلال 14 يوما حسب المادة 17 من القانون رقم 181 لسنة 2018 بشرط سلامة البضاعة. ملف ضريبي 55753/613/293/223/552/06/06368</p>
            <p>تم تسليم البضاعة بحالة جيدة وخالية من العيوب و الضمان مسئولية الشركة المصنعة.</p>
            <p>العنوان: كفر الشيخ - بلطيم</p>
            <p>رقم الهاتف: 010997626230</p>
        </div>
    </div>

    <!-- السكريبتات -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="~/js/script.js"></script>
</body>
</html>
